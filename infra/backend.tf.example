# Rename this file to backend.tf after creating your S3 backend resources.
# Do not commit real bucket names for client/customer environments.

terraform {
  backend "s3" {
    bucket       = "REPLACE_WITH_YOUR_TERRAFORM_STATE_BUCKET"
    key          = "2048-game-devops/terraform.tfstate"
    region       = "us-west-2"
    encrypt      = true
    use_lockfile = true
  }
}
